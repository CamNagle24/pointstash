generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum SyncMethod {
  MANUAL
  SCREENSHOT
  API
  SCRAPE
}

enum ChangeReason {
  MANUAL_UPDATE
  PURCHASE
  REDEMPTION
  PROMOTION
  SYNC
}

enum DealType {
  APP_EXCLUSIVE
  IN_STORE
  ONLINE
  REWARD_MEMBER
}

enum DiscountType {
  FREE_ITEM
  BOGO
  PERCENTAGE_OFF
  DOLLAR_OFF
  POINTS_MULTIPLIER
}

enum DealSource {
  MANUAL
  LLM
  AGGREGATOR
  EXTENSION
}

enum RedemptionCategory {
  ENTREE
  SIDE
  DRINK
  DESSERT
  COMBO
  OTHER
}

model User {
  id               String   @id @default(cuid())
  email            String   @unique
  name             String?
  password         String?
  image            String?
  notifyExpiring   Boolean  @default(true)
  notifyDeals      Boolean  @default(true)
  notifyDigest     Boolean  @default(true)
  notifyAffordable Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  accounts            Account[]
  pointsHistory       PointsHistory[]
  extensionTokens     ExtensionToken[]
  passwordResetTokens PasswordResetToken[]
  deals               Deal[]
  dealReminders       DealReminder[]
  affordabilityAlerts AffordabilityAlert[]
}

// Records that we've emailed a user about a soon-expiring deal, so the daily
// cron doesn't re-send. Keyed on a STABLE logical identity (chainSlug:title),
// not dealId, because deals churn: EXTENSION deals are delete-then-inserted on
// every sync and LLM deals are recreated daily by the scrape cron, so the same
// offer gets a new id repeatedly. sentAt lets us expire old records so a
// genuinely recurring promo can remind again after a while.
model DealReminder {
  id      String   @id @default(cuid())
  userId  String
  // `${chainSlug}:${normalized title}` — survives deal row re-creation.
  dealKey String
  sentAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, dealKey])
  @@index([userId])
}

model SignupAttempt {
  id          String    @id @default(cuid())
  ipHash      String
  createdAt   DateTime  @default(now())

  @@index([ipHash, createdAt])
}

// Records that we've emailed a user about a redemption option that just
// became affordable for one of their accounts, so the daily cron doesn't
// re-send. Unlike `DealReminder` (keyed on a stable string because `Deal`
// rows churn), `RedemptionOption` rows are static seeded catalog data, so a
// direct id-based uniqueness constraint is sufficient. Fires once ever per
// (account, redemption option) pair — never re-armed if the balance dips
// below cost and crosses again later.
model AffordabilityAlert {
  id                 String   @id @default(cuid())
  accountId          String
  userId             String
  redemptionOptionId String
  sentAt             DateTime @default(now())
  account          Account          @relation(fields: [accountId], references: [id], onDelete: Cascade)
  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  redemptionOption RedemptionOption @relation(fields: [redemptionOptionId], references: [id], onDelete: Cascade)

  @@unique([accountId, redemptionOptionId])
  @@index([userId])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model ExtensionToken {
  id         String    @id @default(cuid())
  userId     String
  tokenHash  String    @unique
  label      String?
  createdAt  DateTime  @default(now())
  lastUsedAt DateTime?
  revokedAt  DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Chain {
  id              String  @id @default(cuid())
  slug            String  @unique
  name            String
  logo            String
  color           String
  pointsName      String  @default("points")
  websiteUrl      String
  appDeepLink     String?
  scrapingEnabled Boolean @default(true)

  accounts          Account[]
  deals             Deal[]
  redemptionOptions RedemptionOption[]
}

model Account {
  id            String     @id @default(cuid())
  userId        String
  chainId       String
  loyaltyId     String?
  currentPoints Int        @default(0)
  lastSynced    DateTime?
  syncMethod    SyncMethod @default(MANUAL)
  credentials   Json?
  isActive      Boolean    @default(true)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  user                User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  chain               Chain                @relation(fields: [chainId], references: [id])
  pointsHistory       PointsHistory[]
  affordabilityAlerts AffordabilityAlert[]

  @@unique([userId, chainId])
  @@index([userId])
  @@index([chainId])
}

model PointsHistory {
  id             String       @id @default(cuid())
  accountId      String
  userId         String
  previousPoints Int
  newPoints      Int
  changeReason   ChangeReason
  note           String?
  createdAt      DateTime     @default(now())

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([accountId, createdAt])
  @@index([userId, createdAt])
}

model Deal {
  id            String       @id @default(cuid())
  chainId       String
  // null = global deal (curated/LLM, shown to everyone). Set = a personal
  // offer scraped from this user's logged-in rewards page by the extension.
  userId        String?
  title         String
  description   String?
  dealType      DealType
  discountType  DiscountType
  originalPrice Float?
  dealPrice     Float?
  pointsCost    Int?
  expiresAt     DateTime?
  startsAt      DateTime?
  imageUrl      String?
  sourceUrl     String?
  // Page where the offer is actually redeemable; the "View deal" link appends
  // #ps-deal=<anchorText> so the extension can scroll to + highlight it.
  redeemUrl     String?
  anchorText    String?
  source        DealSource   @default(MANUAL)
  isVerified    Boolean      @default(false)
  isActive      Boolean      @default(true)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  chain Chain @relation(fields: [chainId], references: [id])
  user  User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([chainId, isActive])
  @@index([chainId, source])
  @@index([userId, isActive])
  @@index([expiresAt])
}

model RedemptionOption {
  id                   String             @id @default(cuid())
  chainId              String
  itemName             String
  pointsCost           Int
  estimatedRetailPrice Float
  centsPerPoint        Float
  category             RedemptionCategory
  isAvailable          Boolean            @default(true)
  lastVerified         DateTime           @default(now())
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  chain               Chain                @relation(fields: [chainId], references: [id])
  affordabilityAlerts AffordabilityAlert[]

  @@index([chainId, isAvailable])
  @@index([chainId, centsPerPoint])
}
