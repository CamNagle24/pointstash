# ─── Database ────────────────────────────────────────────────────────────────
# Pooled connection used at runtime. On Supabase use the "transaction pooler"
# string (port 6543, ?pgbouncer=true).
DATABASE_URL=postgresql://user:password@host:6543/postgres?pgbouncer=true

# Direct (un-pooled) connection used by `prisma migrate` and `prisma db push`.
# On Supabase free tier the literal `db.<ref>.supabase.co` host is IPv6-only —
# use the "session pooler" hostname (port 5432) with the `postgres.<ref>` user.
DIRECT_URL=postgresql://user:password@host:5432/postgres

# ─── Auth (NextAuth v5) ──────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=
# Public URL of the deployment. Set to your domain in production.
NEXTAUTH_URL=http://localhost:3000

# Google OAuth — create credentials at console.cloud.google.com →
# APIs & Services → Credentials → OAuth 2.0 Client IDs.
# Authorized redirect URI: <NEXTAUTH_URL>/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Storage ─────────────────────────────────────────────────────────────────
# Vercel Blob — create a Blob store in the Vercel dashboard, copy the token.
BLOB_READ_WRITE_TOKEN=

# ─── Scraping / Cron ─────────────────────────────────────────────────────────
# Shared secret the cron endpoint requires in `Authorization: Bearer <secret>`.
# Vercel Crons send this automatically when set as `CRON_SECRET` in project env.
# Generate with: openssl rand -base64 32
CRON_SECRET=

# ─── Optional ────────────────────────────────────────────────────────────────
# Public token from logo.dev — fetches each chain's official logo by domain.
# Sign up at https://logo.dev (free tier covers small projects). When unset,
# the UI falls back to a gradient-letter mark per chain.
NEXT_PUBLIC_LOGODEV_TOKEN=

# When mocking the API in dev (no DB needed), set to 1. See docs/DEPLOYMENT.md.
NEXT_PUBLIC_ENABLE_MSW=

# Path to a local Tesseract worker bundle for OCR. Leave empty to use the
# bundled worker that tesseract.js downloads on first run.
TESSERACT_WORKER_PATH=

# ─── Email (Resend) ──────────────────────────────────────────────────────────
# Resend API key — create at https://resend.com/api-keys. Free tier covers
# 100 emails/day, 3000/month, plenty for transactional needs.
RESEND_API_KEY=
# From address for outgoing emails. For dev, "onboarding@resend.dev" works
# without domain verification. For production, verify your domain at
# https://resend.com/domains and use something like "PointStash <noreply@pointstash.com>".
RESEND_FROM_EMAIL="PointStash <onboarding@resend.dev>"
# Base URL the password-reset email links to. Falls back to NEXTAUTH_URL.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── PointStash Sync extension ───────────────────────────────────────────────
# Chrome Web Store ID of the published PointStash Sync extension. In dev, load
# the extension/ folder unpacked, copy the ID Chrome assigns, and paste it here.
# In production, replace with the stable Web Store ID after listing.
NEXT_PUBLIC_EXTENSION_ID=
# Public URL of the Chrome Web Store listing. Used as the "install" target when
# the extension isn't detected on the user's browser.
NEXT_PUBLIC_EXTENSION_INSTALL_URL=
