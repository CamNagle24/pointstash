# ─── Database ────────────────────────────────────────────────────────────────
# Pooled connection used at runtime. On Supabase use the "transaction pooler"
# string (port 6543, ?pgbouncer=true).
DATABASE_URL=postgresql://user:password@host:6543/postgres?pgbouncer=true

# Direct (un-pooled) connection used by `prisma migrate` and `prisma db push`.
# On Supabase free tier the literal `db.<ref>.supabase.co` host is IPv6-only —
# use the "session pooler" hostname (port 5432) with the `postgres.<ref>` user.
DIRECT_URL=postgresql://user:password@host:5432/postgres

# ─── Auth (NextAuth v5) ──────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=
# Public URL of the deployment. Set to your domain in production.
NEXTAUTH_URL=http://localhost:3000

# Google OAuth — create credentials at console.cloud.google.com →
# APIs & Services → Credentials → OAuth 2.0 Client IDs.
# Authorized redirect URI: <NEXTAUTH_URL>/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Storage ─────────────────────────────────────────────────────────────────
# Vercel Blob — create a Blob store in the Vercel dashboard, copy the token.
BLOB_READ_WRITE_TOKEN=

# ─── Scraping / Cron ─────────────────────────────────────────────────────────
# Shared secret the cron endpoint requires in `Authorization: Bearer <secret>`.
# Vercel Crons send this automatically when set as `CRON_SECRET` in project env.
# Generate with: openssl rand -base64 32
CRON_SECRET=

# ─── Optional ────────────────────────────────────────────────────────────────
# When mocking the API in dev (no DB needed), set to 1. See docs/DEPLOYMENT.md.
NEXT_PUBLIC_ENABLE_MSW=

# Path to a local Tesseract worker bundle for OCR. Leave empty to use the
# bundled worker that tesseract.js downloads on first run.
TESSERACT_WORKER_PATH=
